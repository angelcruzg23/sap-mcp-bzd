# ============================================
# Configuración MCP Server — S/4HANA Cloud Public Edition
# Opción: JWT Auth via XSUAA (recomendado)
# ============================================

SAP_AUTH_TYPE=jwt
SAP_URL=https://<tenant-id>.abap.<region>.hana.ondemand.com
SAP_JWT_TOKEN=eyJhbGciOiJSUzI1NiIsImp...
SAP_VERIFY_SSL=true
SAP_TIMEOUT_DEFAULT=45
SAP_TIMEOUT_CSRF=15
SAP_TIMEOUT_LONG=60

# ============================================
# Datos del Service Key (para regenerar token)
# NO commitear estos valores al repositorio
# ============================================
# BTP_UAA_URL=https://<subdomain>.authentication.<region>.hana.ondemand.com
# BTP_CLIENT_ID=sb-<guid>!b<number>|abap-trial-service-broker!b<number>
# BTP_CLIENT_SECRET=<client_secret>
# BTP_USERNAME=tu-usuario@empresa.com
