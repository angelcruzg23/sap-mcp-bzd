# ============================================
# Configuración MCP Server — S/4HANA Cloud Public Edition
# Opción: Basic Auth (si el tenant lo permite)
# ============================================

SAP_AUTH_TYPE=basic
SAP_URL=https://<tenant-id>.s4hana.ondemand.com
SAP_CLIENT=080
SAP_USER=TU_USUARIO_DESARROLLO
SAP_PASS=TU_PASSWORD
SAP_VERIFY_SSL=true
SAP_TIMEOUT_DEFAULT=45
SAP_TIMEOUT_CSRF=15
SAP_TIMEOUT_LONG=60
